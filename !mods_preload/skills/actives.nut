::mods_hookNewObject("skills/actives/rally_the_troops", function ( o )
{
	o.m.Name = "Pokrzep Towarzyszy";
	o.m.Description = "Do boju! Użyj inspirującej stanowczości tej postaci, aby pokrzepić i poderwać do boju pobliskich uciekających sojuszników i natchnąć każdego, by dał z siebie wszystko. Dana postać może zostać pokrzepiona tylko raz na rundę.";
	o.getTooltip = function ()
	{
		local bravery = this.Math.max(0, this.Math.floor(this.getContainer().getActor().getCurrentProperties().getBravery() * 0.4));
		local ret = [
			{
				id = 1,
				type = "title",
				text = this.getName()
			},
			{
				id = 2,
				type = "description",
				text = this.getDescription()
			},
			{
				id = 3,
				type = "text",
				text = this.getCostString()
			},
			{
				id = 7,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Wyzwala test morale, aby pokrzepić uciekających sojuszników w zasięgu 4 pól, z premią do Stanowczości w wysokości [color=" + this.Const.UI.Color.PositiveValue + "]+" + bravery + "[/color], bazując na Stanowczości tej postaci"
			},
			{
				id = 7,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Wyzwala test morale na podwyższenie morale każdej postaci w zasięgu 4 pól o morale zachwianym lub gorszym, z premią do Stanowczości w wysokości [color=" + this.Const.UI.Color.PositiveValue + "]+" + bravery + "[/color] bazując na Stanowczości tej postaci, ale obniżoną o [color=" + this.Const.UI.Color.NegativeValue + "]-10[/color] na każde pole odległości"
			},
			{
				id = 7,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Budzi ze snu sojuszników w zasięgu 4 pól"
			}
		];

		if (this.getContainer().hasSkill("effects.rallied"))
		{
			ret.push({
				id = 9,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Nie można pokrzepić innych będąc w tej samej turze pokrzepionym[/color]"
			});
		}

		return ret;
	};
});
::mods_hookNewObject("skills/actives/reap_skill", function ( o )
{
	o.m.Name = "Żnij";
	o.m.Description = "Zamaszyste uderzenie po szerokim łuku, które na pewną odległość trafia trzy sąsiednie pola w kierunku przeciwnym do ruchu wskazówek zegara.  Ostrożnie z używaniem tej zdolności w pobliżu własnych ludzi, chyba że chcesz zmniejszyć swoją listę płac!";
	o.getTooltip = function ()
	{
		local ret = this.getDefaultTooltip();
		ret.push({
			id = 6,
			type = "text",
			icon = "ui/icons/special.png",
			text = "Może trafić aż 3 cele"
		});
		ret.push({
			id = 7,
			type = "text",
			icon = "ui/icons/vision.png",
			text = "Ma zasięg [color=" + this.Const.UI.Color.PositiveValue + "]2" + "[/color] pól"
		});

		if (!this.getContainer().getActor().getCurrentProperties().IsSpecializedInPolearms)
		{
			ret.push({
				id = 6,
				type = "text",
				icon = "ui/icons/hitchance.png",
				text = "Ma [color=" + this.Const.UI.Color.NegativeValue + "]-15%[/color] szansy na trafienie celów bezpośrednio sąsiadujących, ponieważ broń jest zbyt nieporęczna"
			});
		}

		return ret;
	};
});
::mods_hookNewObject("skills/actives/rotation", function ( o )
{
	o.m.Name = "Rotacja";
	o.m.Description = "Zamień się miejscami z inną postacią bezpośrednio sąsiadującą, o ile ani cel, ani używający tej umiejętności nie są ogłuszeni lub ukorzenieni. Dokonuj rotacji w szeregach, by zdrowe i rześkie jednostki trzymać z przodu";
	o.getTooltip = function ()
	{
		local value = this.Math.round(this.Math.minf(0.5, this.getContainer().getActor().getCurrentProperties().Bravery * 0.005) * 100);
		local ret = [
			{
				id = 1,
				type = "title",
				text = this.getName()
			},
			{
				id = 2,
				type = "description",
				text = this.getDescription()
			},
			{
				id = 3,
				type = "text",
				text = this.getCostString()
			}
		];

		if (this.getContainer().getActor().getCurrentProperties().IsRooted)
		{
			ret.push({
				id = 9,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Nie można użyć będąc ukorzenionym[/color]"
			});
		}

		return ret;
	};
});
::mods_hookNewObject("skills/actives/round_swing", function ( o )
{
	o.m.Name = "Okrężny Zamach";
	o.m.Description = "Skoś tym szaleńczym ciosem wszystkich wokół ciebie, czy to wróg, czy przyjaciel. Nietrudno uniknąć tego ciosu, bo nie jest mierzone w nic konkretnego, choć może być druzgocące, jeżeli trafi. Ostrożnie z używaniem tej zdolności w pobliżu własnych ludzi, chyba że chcesz zmniejszyć swoją listę płac!";
	o.m.KilledString = "Porąbany na kawałki";
	o.getTooltip = function ()
	{
		local ret = this.getDefaultTooltip();
		local hitchanceBonus = this.m.HitChanceBonus;

		if (this.getContainer().getActor().getCurrentProperties().IsSpecializedInAxes)
		{
			hitchanceBonus = hitchanceBonus + 5;
		}

		ret.extend([
			{
				id = 7,
				type = "text",
				icon = "ui/icons/hitchance.png",
				text = "Ma [color=" + this.Const.UI.Color.NegativeValue + "]" + hitchanceBonus + "%[/color] szansy na trafienie"
			},
			{
				id = 6,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Może trafić aż 6 celów"
			}
		]);
		return ret;
	};
});
::mods_hookNewObject("skills/actives/rupture", function ( o )
{
	o.m.Name = "Rozłam";
	o.m.Description = "Pchnięcie, które sięga aż na 2 pola i może zostać użyte zza przedniego szeregu, będąc poza zasięgiem większości broni białej, i które zadaje krwawiące rany szarpane, jeśli nie zostanie zatrzymane przez pancerz.";
	o.m.KilledString = "Nadziany";
	o.getTooltip = function ()
	{
		local ret = this.getDefaultTooltip();
		ret.extend([
			{
				id = 7,
				type = "text",
				icon = "ui/icons/vision.png",
				text = "Ma zasięg [color=" + this.Const.UI.Color.PositiveValue + "]2[/color] pól"
			},
			{
				id = 8,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Zadaje dodatkowe [color=" + this.Const.UI.Color.DamageValue + "]" + 10 + "[/color] obrażeń od krwawienia na turę, jeśli nie zostanie zatrzymane przez pancerz"
			}
		]);
		ret.push({
			id = 6,
			type = "text",
			icon = "ui/icons/hitchance.png",
			text = "Ma [color=" + this.Const.UI.Color.PositiveValue + "]+5%[/color] szansy na trafienie"
		});

		if (!this.getContainer().getActor().getCurrentProperties().IsSpecializedInPolearms)
		{
			ret.push({
				id = 6,
				type = "text",
				icon = "ui/icons/hitchance.png",
				text = "Ma [color=" + this.Const.UI.Color.NegativeValue + "]-15%[/color] szansy na trafienie celów bezpośrednio sąsiadujących, ponieważ broń jest zbyt nieporęczna"
			});
		}

		return ret;
	};
});
