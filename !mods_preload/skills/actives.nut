::mods_hookNewObject("skills/actives/hail_skill", function ( o )
{
	o.m.Name = "Gradobicie";
	o.m.Description = "Wyceluj w głowę przeciwnika. Każda głowica oddzielnie może chybić lub trafić, zadając jedną trzecią obrażeń broni. Wszystkie głowice uderzą ponad lub wokół tarczy.";
