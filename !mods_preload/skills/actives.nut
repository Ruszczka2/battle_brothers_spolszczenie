	{
		local ret = this.getDefaultTooltip();
		ret.extend([
			{
				id = 9,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Ma [color=" + this.Const.UI.Color.PositiveValue + "]100%[/color] szansy na trafienie w głowę"
			},
			{
				id = 7,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Wykona trzy oddzielne ataki, a każdy zada jedną trzecią obrażeń broni"
			}
		]);

		if (this.getContainer().getActor().getCurrentProperties().IsSpecializedInFlails)
		{
			ret.push({
				id = 8,
				type = "text",
				icon = "ui/icons/special.png",
				text = "Ignoruje premię do Obrony w zwarciu przyznaną przez tarczę"
			});
		}

		return ret;
	};
});
