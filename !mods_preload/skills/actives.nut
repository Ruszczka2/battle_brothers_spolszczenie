::mods_hookNewObject("skills/actives/break_ally_free_skill", function ( o )
{
	o.m.Name = "Uwolnij Sojusznika";
	o.m.Description = "Użyj wszystkiego, co masz do dyspozycji, aby uwolnić pobliskiego sojusznika z tego, co go uwięziło w miejscu. Rąb, siekaj, tnij lub nawet gryź, jeśli zajdzie potrzeba!";
	o.getTooltip = function ()
	{
		local chance = this.Math.min(100, this.getContainer().getActor().getCurrentProperties().getMeleeSkill() - 10);
		return [
			{
				id = 1,
				type = "title",
				text = this.getName()
			},
			{
				id = 2,
				type = "description",
				text = this.getDescription()
			},
			{
				id = 3,
				type = "text",
				text = this.getCostString()
			},
			{
				id = 4,
				type = "text",
				icon = "ui/icons/melee_skill.png",
				text = "Ma [color=" + this.Const.UI.Color.PositiveValue + "]" + chance + "%[/color] szansy na powodzenie, bazując na Ataku w zwarciu. Szansa jest wyższa, jeśli już próbowano uwolnić cel."
			}
		];
	};
});
::mods_hookNewObject("skills/actives/fire_handgonne_skill", function ( o )
{
	o.m.Name = "Wystrzel z Rusznicy";
	o.m.Description = "Podpal lont swojej Rusznicy. Może trafić wiele celów za jednym wystrzałem, ale bardziej oddalone cele mają mniejszą szansę na zostanie trafionymi. Umiejętność nie może być użyta, gdy postać sąsiaduje z wrogiem walczącym wręcz.";
	o.getTooltip = function ()
	{
		local ret = this.getDefaultTooltip();
		ret.push({
			id = 10,
			type = "text",
			icon = "ui/icons/special.png",
			text = "Can hit up to 6 targets"
		});
		ret.push({
			id = 6,
			type = "text",
			icon = "ui/icons/vision.png",
			text = "Ma zasięg [color=" + this.Const.UI.Color.PositiveValue + "]" + this.getMaxRange() + "[/color] pól na równym terenie i [color=" + this.Const.UI.Color.PositiveValue + "]" + (this.getMaxRange() + this.m.MaxRangeBonus) + "[/color] pól strzelając ze wzniesienia"
		});

		if (10 + this.m.AdditionalAccuracy >= 0)
		{
			ret.push({
				id = 7,
				type = "text",
				icon = "ui/icons/hitchance.png",
				text = "Ma [color=" + this.Const.UI.Color.PositiveValue + "]+" + (10 + this.m.AdditionalAccuracy) + "%[/color] szansy na trafienie i [color=" + this.Const.UI.Color.NegativeValue + "]" + (-10 + this.m.AdditionalHitChance) + "%[/color] na każde pole odległości. Na tę szansę nie mają wpływu obiekty i postacie na linii ognia."
			});
		}
		else
		{
			ret.push({
				id = 7,
				type = "text",
				icon = "ui/icons/hitchance.png",
				text = "Ma [color=" + this.Const.UI.Color.NegativeValue + "]" + (10 + this.m.AdditionalAccuracy) + "%[/color] szansy na trafienie i [color=" + this.Const.UI.Color.NegativeValue + "]" + (-10 + this.m.AdditionalHitChance) + "%[/color] na każde pole odległości.  Na tę szansę nie mają wpływu obiekty i postacie na linii ognia."
			});
		}

		local ammo = this.getAmmo();

		if (ammo > 0)
		{
			ret.push({
				id = 8,
				type = "text",
				icon = "ui/icons/ammo.png",
				text = "Ma [color=" + this.Const.UI.Color.PositiveValue + "]" + ammo + "[/color] wystrzałów w zapasie"
			});
		}
		else
		{
			ret.push({
				id = 8,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Wymaga założonej torby z prochem, która nie jest pusta[/color]"
			});
		}

		if (!this.getItem().isLoaded())
		{
			ret.push({
				id = 9,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Musi zostać przeładowana przed ponownym strzałem[/color]"
			});
		}

		if (this.Tactical.isActive() && this.getContainer().getActor().getTile().hasZoneOfControlOtherThan(this.getContainer().getActor().getAlliedFactions()))
		{
			ret.push({
				id = 9,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Nie można użyć, gdyż wróg zbliżył się na odległość walki wręcz[/color]"
			});
		}

		return ret;
	};
});
::mods_hookNewObject("skills/actives/ghost_split_skill", function ( o )
{
	o.m.Name = "Rozetnij";
	o.m.Description = "Zamaszysty atak wyprowadzony znad głowy dla jak największego zasięgu, zamiast jak największej siły, który może pokryć aż dwa pola w linii prostej.";
	o.m.KilledString = "Rozcięty na pół";
