local uproot_effect = function ( _user, _target, _targetTile )
{
	if (_target.isNonCombatant())
	{
		return;
	}

	_target.getSkills().add(this.new("scripts/skills/effects/staggered_effect"));

	if (!_user.isHiddenToPlayer() && _targetTile.IsVisibleForPlayer)
	{
		this.Tactical.EventLog.log(this.Const.UI.getColorizedEntityName(_user) + " wytrąca z równowagi: " + this.Const.UI.getColorizedEntityName(_target) + " na jedną turę");
	}
};
