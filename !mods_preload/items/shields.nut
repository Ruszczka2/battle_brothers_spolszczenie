::mods_hookNewObject("items/shields/special/craftable_schrat_shield", function ( o )
{
	o.m.Name = "Tarcza z Żyjącego Drzewa";
	o.m.Description = "Ta tarcza została wyciosana z resztek żyjącego drzewa i powoli odrasta, jeśli zostanie naruszona. Gdy rzuci się na nią okiem, to wydaje się, jakby jej groteskowa twarz nadal się poruszała.";
	local gtt = o.getTooltip;
	o.getTooltip = function ()
	{
		local result = gtt();
		result.push({
			id = 6,
			type = "text",
			icon = "ui/icons/special.png",
			text = "Regeneruje się o [color=" + this.Const.UI.Color.PositiveValue + "]20[/color] punktów wytrzymałości na każdą turę"
		});
		return result;
	};
});
::mods_hookNewObject("items/shields/legendary/gilders_embrace_shield", function ( o )
{
	o.m.Name = "Uścisk Złotnika";
	o.m.Description = "Zdobiona metalowa tarcza z jasnym złocistym połyskiem, który odbija nawet najmniejsze promienie światła z siłą samego słońca.";
	o.getTooltip = function ()
	{
		local result = [
			{
				id = 1,
				type = "title",
				text = this.getName()
			},
			{
				id = 2,
				type = "description",
				text = this.getDescription()
			}
		];

		if (this.getIconLarge() != null)
		{
			result.push({
				id = 3,
				type = "image",
				image = this.getIconLarge(),
				isLarge = true
			});
		}
		else
		{
			result.push({
				id = 3,
				type = "image",
				image = this.getIcon()
			});
		}

		result.push({
			id = 66,
			type = "text",
			text = this.getValueString()
		});
		result.push({
			id = 4,
			type = "progressbar",
			icon = "ui/icons/asset_supplies.png",
			value = this.m.Condition,
			valueMax = this.m.ConditionMax,
			text = "" + this.m.Condition + " / " + this.m.ConditionMax + "",
			style = "armor-head-slim"
		});
		result.push({
			id = 5,
			type = "text",
			icon = "ui/icons/melee_defense.png",
			text = "Obrona w zwarciu [color=" + this.Const.UI.Color.PositiveValue + "]+" + this.m.MeleeDefense + "[/color]"
		});
		result.push({
			id = 6,
			type = "text",
			icon = "ui/icons/ranged_defense.png",
			text = "Obrona dystansowa [color=" + this.Const.UI.Color.PositiveValue + "]+" + this.m.RangedDefense + "[/color]"
		});
		result.push({
			id = 7,
			type = "text",
			icon = "ui/icons/fatigue.png",
			text = "Maksymalne zmęczenie [color=" + this.Const.UI.Color.NegativeValue + "]" + this.m.StaminaModifier + "[/color]"
		});
		result.push({
			id = 8,
			type = "text",
			icon = "ui/icons/special.png",
			text = "Niezniszczalna"
		});
		result.push({
			id = 8,
			type = "text",
			icon = "ui/icons/special.png",
			text = "Ktokolwiek uderzy w tę tarczę zostanie \'Oszołomiony\'"
		});
		return result;
	};
	o.onShieldHit = function ( _attacker, _skill )
	{
		if (_attacker != null && _attacker.isAlive() && !_attacker.isDying())
		{
			_attacker.getSkills().add(this.new("scripts/skills/effects/dazed_effect"));

			if (_attacker.getTile().IsVisibleForPlayer)
			{
				this.Tactical.EventLog.log(this.Const.UI.getColorizedEntityName(_attacker) + " ulega oszołomieniu przez Uścisk Złotnika");
			}
		}
	};
});
::mods_hookDescendants("items/shields/shield", function ( o )
{
	while (!("getTooltip" in o))
	{
		o = o[o.SuperName];
	}

	o.getTooltip = function ()
	{
		local result = [
			{
				id = 1,
				type = "title",
				text = this.getName()
			},
			{
				id = 2,
				type = "description",
				text = this.getDescription()
			}
		];

		if (this.getIconLarge() != null)
		{
			result.push({
				id = 3,
				type = "image",
				image = this.getIconLarge(),
				isLarge = true
			});
		}
		else
		{
			result.push({
				id = 3,
				type = "image",
				image = this.getIcon()
			});
		}

		result.push({
			id = 66,
			type = "text",
			text = this.getValueString()
		});
		result.push({
			id = 4,
			type = "progressbar",
			icon = "ui/icons/asset_supplies.png",
			value = this.getCondition(),
			valueMax = this.getConditionMax(),
			text = "" + this.getCondition() + " / " + this.getConditionMax() + "",
			style = "armor-head-slim"
		});

		if (this.m.MeleeDefense > 0)
		{
			result.push({
				id = 5,
				type = "text",
				icon = "ui/icons/melee_defense.png",
				text = "Obrona w zwarciu [color=" + this.Const.UI.Color.PositiveValue + "]+" + this.m.MeleeDefense + "[/color]"
			});
		}

		if (this.m.RangedDefense > 0)
		{
			result.push({
				id = 6,
				type = "text",
				icon = "ui/icons/ranged_defense.png",
				text = "Obrona dystansowa [color=" + this.Const.UI.Color.PositiveValue + "]+" + this.m.RangedDefense + "[/color]"
			});
		}

		if (this.m.StaminaModifier < 0)
		{
			result.push({
				id = 7,
				type = "text",
				icon = "ui/icons/fatigue.png",
				text = "Maksymalne zmęczenie [color=" + this.Const.UI.Color.NegativeValue + "]" + this.m.StaminaModifier + "[/color]"
			});
		}

		if (this.m.FatigueOnSkillUse > 0)
		{
			result.push({
				id = 8,
				type = "text",
				icon = "ui/icons/fatigue.png",
				text = "Umiejętności tarczy generują o [color=" + this.Const.UI.Color.NegativeValue + "]" + this.m.FatigueOnSkillUse + "[/color] więcej zmęczenia"
			});
		}
		else if (this.m.FatigueOnSkillUse < 0)
		{
			result.push({
				id = 8,
				type = "text",
				icon = "ui/icons/fatigue.png",
				text = "Umiejętności tarczy generują o [color=" + this.Const.UI.Color.PositiveValue + "]" + this.m.FatigueOnSkillUse + "[/color] mniej zmęczenia"
			});
		}

		if (this.m.Condition == 0)
		{
			result.push({
				id = 10,
				type = "text",
				icon = "ui/tooltips/warning.png",
				text = "[color=" + this.Const.UI.Color.NegativeValue + "]Zniszczona i nie nadająca się do użytku[/color]"
			});
		}

		return result;
	};
});

