::mods_hookNewObject("items/loot/ancient_amber_item", function ( o )
{
	o.m.Name = "Starożytny Bursztyn";
	o.m.Description = "Na korze wyjątkowo starych schratów czasem tworzą się odłamki niezwykle czystych bursztynów. Te zaś osiągają dość wysokie ceny u kupców.";
});
::mods_hookNewObject("items/loot/ancient_gold_coins_item", function ( o )
{
	o.m.Name = "Starożytne Złote Monety";
	o.m.Description = "Grube złote monety z wybitymi różnymi starożytnymi wzorami. Powinny być warte sporo, jeśli znajdziesz na nie kupca.";
});
::mods_hookNewObject("items/loot/bead_necklace_item", function ( o )
{
	o.m.Name = "Naszyjnik z Korali";
	o.m.Description = "Naszyjnik wykonany z różnych koralików, typowy dla północnych plemion barbarzyńskich.";
});
::mods_hookNewObject("items/loot/bone_figurines_item", function ( o )
{
	o.m.Name = "Kościane Figurki";
	o.m.Description = "Małe rzeźbione figurki wykonane z różnych rzadkich kości. Jakiś kolekcjoner może za nie nieźle zapłacić.";
});
::mods_hookNewObject("items/loot/deformed_valuables_item", function ( o )
{
	o.m.Name = "Zdeformowane Kosztowności";
	o.m.Description = "Unholdy są niezdarnymi, lecz potężnymi stworami i bywa, że miażdżą i zgniatają znalezione przez siebie kosztowności w poręczną, krzywą kulę.";
});
::mods_hookNewObject("items/loot/gemstones_item", function ( o )
{
	o.m.Name = "Kamienie Szlachetne";
	o.m.Description = "Obrobione kamienie szlachetne różnych rozmiarów. Powinny być warte wiele, jeśli znajdziesz na nie kupca.";
});
::mods_hookNewObject("items/loot/glittering_rock_item", function ( o )
{
	o.m.Name = "Lśniący Kamień";
	o.m.Description = "Pomiędzy porozrzucanymi kamieniami, które pozostały po pokonanym Ifricie, czasami można znaleźć lśniący złotem kamień. To wartościowe trofeum.";
});
::mods_hookNewObject("items/loot/goblin_carved_ivory_iconographs_item", function ( o )
{
	o.m.Name = "Rzeźbiona w Kości Ikona";
	o.m.Description = "Zdolnie wyrzeźbiona w kości ikona, przedstawiająca szanowanych członków goblińskiej społeczności.";
});
::mods_hookNewObject("items/loot/goblin_minted_coins_item", function ( o )
{
	o.m.Name = "Wybite Srebrne Monety";
	o.m.Description = "Wybite srebrne monety, których gobliny używają jako waluty.";
});
::mods_hookNewObject("items/loot/goblin_rank_insignia_item", function ( o )
{
	o.m.Name = "Złote Insygnia";
	o.m.Description = "Takie złote insygnia noszone są przez wysokich rangą oficjeli goblińskich. Powinny być coś warte dla kolekcjonera.";
});
::mods_hookNewObject("items/loot/golden_chalice_item", function ( o )
{
	o.m.Name = "Złoty Kielich";
	o.m.Description = "Puchar do trunków wykonany ze szczerego złota. Powinien być wart wiele, jeśli znajdziesz na niego kupca.";
});
::mods_hookNewObject("items/loot/growth_pearls_item", function ( o )
{
	o.m.Name = "Perliste Narośla";
	o.m.Description = "Szybko rosnąca tkanka Nachzehrerów czasami pochłania lub zalewa małe cząsteczki lub gruzy, przemieniając je w lśniące perły, które można znaleźć pomiędzy stworami. Powinny sprzedać się za niemałą sumkę w najbliższym mieście.";
});
::mods_hookNewObject("items/loot/jade_broche_item", function ( o )
{
	o.m.Name = "Nefrytowa Broszka";
	o.m.Description = "Pięknie wykonana nefrytowa broszka, która z pewnością warta jest z monetę lub dwie.";
});
::mods_hookNewObject("items/loot/jeweled_crown_item", function ( o )
{
	o.m.Name = "Korona z Klejnotami";
	o.m.Description = "Wspaniale wykonana złota korona obsadzona klejnotami. Powinna być warta fortunę, jeśli znajdziesz kupca.";
});
::mods_hookNewObject("items/loot/lindwurm_hoard_item", function ( o )
{
	o.m.Name = "Skarb Lindwurma";
	o.m.Description = "Kolekcja błyszczących kosztowności, pokryta wnętrznościami Lindwurma.";
});
::mods_hookNewObject("items/loot/looted_valuables_item", function ( o )
{
	o.m.Name = "Zrabowane Kosztowności";
	o.m.Description = "Stos kosztowności, który został złupiony i zebrany przez Barbarzyńców przez lata. Wiele części jest zniszczonych i powyginanych, ale materiały są dość kunsztowne.";
});
::mods_hookNewObject("items/loot/ornate_tome_item", function ( o )
{
	o.m.Name = "Zdobiony Tom";
	o.m.Description = "Dobrze zachowany tom z masywną złotą okładką. Powinien sprzedać się za niezłą sumkę u osób, które studiują stare zakurzone księgi.";
});
::mods_hookNewObject("items/loot/rainbow_scale_item", function ( o )
{
	o.m.Name = "Tęczowa Łuska";
	o.m.Description = "Pustynne węże czasami miewają wyjątkowo kolorowe i lśniące łuski na swej migoczącej skórze. Takie łuski są wielce pożądane przez jubilerów i łowców trofeów.";
});
::mods_hookNewObject("items/loot/sabertooth_item", function ( o )
{
	o.m.Name = "Szabloząb";
	o.m.Description = "Niebywale wielki ząb, który pewnie może zostać sprzedany za garść koron ludziom, którzy chcą poudawać, że upolowali przerażającą bestię.";
});
::mods_hookNewObject("items/loot/signet_ring_item", function ( o )
{
	o.m.Name = "Sygnet";
	o.m.Description = "Sygnet z klejnotami. Powinien sprzedać się za niemałą sumkę w najbliższym mieście.";
});
::mods_hookNewObject("items/loot/silver_bowl_item", function ( o )
{
	o.m.Name = "Srebrna Misa";
	o.m.Description = "Duża srebrna misa niesamowitej wagi. Powinna sprzedać się za niemałą sumkę w najbliższym mieście.";
});
::mods_hookNewObject("items/loot/silverware_item", function ( o )
{
	o.m.Name = "Srebro Stołowe";
	o.m.Description = "Zbiór srebrnych sztućców. Powinny sprzedać się za niemałą sumkę w najbliższym mieście.";
});
::mods_hookNewObject("items/loot/soul_splinter_item", function ( o )
{
	o.m.Name = "Odłamek Duszy";
	o.m.Description = "W pylastych resztkach Alpów czasami można odnaleźć te czarne niczym smoła odłamki. Wyglądają jakby gdzieś w głębi tych kamieni lśniły gwiazdy.";
});
::mods_hookNewObject("items/loot/valuable_furs_item", function ( o )
{
	o.m.Name = "Wartościowe Futra";
	o.m.Description = "Paczka wartościowych futer i skór różnych zwierząt. Bardzo pożądany towar, zwłaszcza w większych miastach.";
});
::mods_hookNewObject("items/loot/webbed_valuables_item", function ( o )
{
	o.m.Name = "Kosztowności Pokryte Pajęczynami";
	o.m.Description = "Pomiędzy gęstymi sieciami webknechtów czasami można odkryć kosztowności, które niegdyś należały do ich nieszczęsnych ofiar - o ile ktoś jest odważny na tyle, by przeszukiwać te kleiste, śmiertelne pułapki.";
});
::mods_hookNewObject("items/loot/white_pearls_item", function ( o )
{
