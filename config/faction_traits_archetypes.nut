local gt = this.getroottable();
gt.Const.FactionArchetypes <- [
	[
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Warmonger,
				this.Const.FactionTrait.ManOfThePeople
			],
			Description = "Ród %noblehousename% obraca się wokół religijnego kultu, który uczy współczucia wobec swoich, lecz przez to stali się pełni pogardy i pozbawieni litości wobec swych wrogów. Pokolenia temu, wielka inwazja orków splądrowała i zniszczyła większość włości rodu, który nigdy już nie powrócił do dawnej świetności. Od tamtego czasu ród poprowadził wiele krucjat i ekspedycji karnych daleko w głąb terytorium orków, choć nigdy nie udało im się na dobre wyplenić zielonoskórych.",
			Mottos = [
				"Cnota to jedyna szlachetność",
				"W obronie potrzebującym",
				"Zapał i honor",
				"Szlachetni w gniewie",
				"Oczyszczeni przez ogień",
				"Pokój zdobywa się poprzez wojnę",
				"Póki oddychamy, mamy nadzieję",
				"Śmiało i honorowo",
				"Gardzimy zmianą i strachem",
				"Zwycięstwo leży w prawdzie",
				"Światło w Ciemności",
				"Jedno serce, jedna droga"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Sheriff,
				this.Const.FactionTrait.ManOfThePeople
			],
			Description = "Ród %noblehousename% wielce poważa zasady sprawiedliwości i honoru, a pozbawiony nieracjonalnych rządów w swym regionie, rozkwitł. Ich reputacja może i jest pokojowa, lecz rycerze rodu %noblehousename% są zaprawieni w boju, a ich żołdacy zaciekle będą walczyć z każdym, kto zagraża ich królestwu, wartościom i zasadom. Wielu szlachciców zazdrości im ich bogactwa i wyśmiewa ich cnoty; ród %othernoblehouse% w szczególności chowa tu urazę wobec rodu %noblehousename%.",
			Mottos = [
				"Żyj, abyś mógł żyć",
				"Przyjaźń bez podstępów",
				"Ośmiel się być mądrym",
				"Odważni zawsze okazują litość",
				"Przyjaciele dla przyjaciół",
				"Ta dłoń jest wroga dla tyranów",
				"Nie denerwuj lwa",
				"Dąb w wiekowej sile",
				"Serce dłoń prowadzi",
				"Zawsze na straży",
				"Chwała ojcu",
				"Cnota skryta w sile",
				"Przygotowani na każdą ewentualność",
				"Nie dla nas samych"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Sheriff,
				this.Const.FactionTrait.Collector
			],
			Description = "Wielu szuka bogactwa, lecz wysoce szanowani kupcy rodu %noblehousename% osiągnęli mistrzostwo w dobijaniu korzystnych targów. Powiązani przez rodowe więzi z reputacją swych praprzodków, hołdują dawnym wartościom, takim jak uczciwość i prawość.",
			Mottos = [
				"Rozum jest przewodnikiem życia",
				"Pewni w działaniu i łagodni w manierach",
				"Niech nas oceniają po czynach",
				"Próbuj i nie żałuj",
				"Słońce wyłania się spośród chmur",
				"Odwaga w trudnych chwilach",
				"Urodzaj bierze się z pracowitości"
			]
		}
	],
	[
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Warmonger,
				this.Const.FactionTrait.Tyrant
			],
			Description = "Szlachecki ród %noblehousename% jest rodem dumnym i bezlitosnym, z długą i zbroczoną krwią historią podbojów. Rezydując w swej fortecy w %factionfortressname%, siłą zabierają to, co według nich im się należy. Dawna waśń z rodem %othernoblehouse% wciąż sprawia, że nie gaśnie nienawiść w ich sercach, ani ogień w ich kuźniach.",
			Mottos = [
				"Trwaj przy własnych mocach",
				"Podbija ten, kto trwa",
				"Śmiali i słuszni",
				"Pod tym herbem będziesz podbijać",
				"Nie umiera ten, czyja sława trwa",
				"Ani kroku wstecz",
				"Poprzez strzały i wrogów",
				"Nic nie oprze się męstwu i orężowi",
				"Taka jest droga do nieśmiertelności",
				"My takoż rzuciliśmy oszczepy",
				"Czapla szuka wysokich miejsc"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Warmonger,
				this.Const.FactionTrait.Marauder
			],
			Description = "Wzgardzony za swą bezwzględność, brutalność i chciwość ród %noblehousename% nie brata się zbytnio z innymi rodami szlacheckimi. Ich kapitanowie i żołnierze znani są z napadania na karawany kupieckie, gospodarstwa rolne i mniejsze osady, znajdujące się w pobliżu ich fortecy %factionfortressname%. Życie niewielką ma wartość w królestwie rodu %noblehousename% i wielu najemników, którzy szukali tu szybkiego zarobku, zamiast niego znalazło szybką śmierć.",
			Mottos = [
				"Wszystko co rośnie, ginie w popiołach",
				"Rozdepczemy to pod własnymi stopami",
				"Dla mnie i moich bliskich",
				"Orzeł nie chwyta much",
				"Czyny, nie słowa",
				"Bogowie karmią kruki",
				"Wiecznie nienasyceni",
				"Synowie ogarów przybądźcie i ucztujcie",
				"Liczy się łup"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Schemer,
				this.Const.FactionTrait.Tyrant
			],
			Description = "Ród %noblehousename% jest znienawidzony przez wielu, jednak jeszcze więcej ludzi się go lęka. Kilka małych i większych buntów zostało brutalnie stłumionych ogniem i mieczem, a pachołkowie rodu %noblehousename% znani są z tego, że mają oczy w każdym ciemnym zakątku i uszy w każdej ścianie. Rodowa siedziba %factionfortressname% roi się od uzbrojonych straży, węszących wojennych ogarów i rosłych najemników, ochraniających swych paranoicznych przywódców.",
			Mottos = [
				"Nóż w ciemności",
				"Przycinanie stymuluje wzrost",
				"Zawsze gotowi",
				"Obrońca nie zasypia",
				"Broń utrzymuje pokój",
				"Niewinni niczym gołębie",
				"Stanowczy w swych celach",
				"Bądź posłuszny",
				"Prawem i bronią",
				"Naucz się wytrzymywać to, co znieść trzeba",
				"Gniew lwa jest szlachetny"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Marauder,
				this.Const.FactionTrait.Tyrant
			],
			Description = "Ród %noblehousename% jest szeroko znany ze swego wystawnego stylu życia i bachanalii. A jako że ktoś cenę za to zapłacić musi, to na wpół zagłodzone bydło, puste spichlerze i zdesperowani podwładni są dość powszechnym widokiem wszędzie tam, gdzie rządzi ród %noblehousename%. Mimo iż inne rody krzywo patrzą na taką brutalność i rozrzutność, to jednocześnie z niecierpliwością wyczekują zaproszenia na kolejną ucztę.",
			Mottos = [
				"Niepokonani",
				"Okrutna plotka, ale jednak",
				"Wznoszę się",
				"Bo się należy",
				"Gardzę",
				"Owieczki, macie wełnę",
				"Nie okazuj litości",
				"Zysk przychodzi z niebezpieczeństwa",
				"Pamiętaj, że umrzesz"
			]
		}
	],
	[
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Schemer,
				this.Const.FactionTrait.Collector
			],
			Description = "Handel i targowanie się mogą być równie zaciekłe, co toczenie wojen, a ród %noblehousename% jest prawdziwym mistrzem przebiegłego dobijania targów. Plotka głosi, że wiele korzystnych umów zawartych przez ród %noblehousename% opiera się nie tylko na uczciwym targowaniu, lecz też na łapówkach, wymuszeniach i oszustwach. Rodzina rezyduje w napuszonym rejonie stolicy %factionfortressname%, jednak pomimo posiadania swych niezliczonych bogactw znana jest ze swego niebywałego skąpstwa.",
			Mottos = [
				"Żyć bez ukrytych pragnień",
				"Los sprzyja śmiałym",
				"Świat to za mało",
				"Oddziel uczciwych od użytecznych",
				"Nasze żniwa również nadejdą",
				"Zdobywam poprzez ryzyko"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.ManOfThePeople,
				this.Const.FactionTrait.Collector
			],
			Description = "Ród %noblehousename% twierdzi, że jego korzenie sięgają czasów, gdy ludzie po raz pierwszy osiedli na tych ziemiach, a pierwszy król rządził całą krainą. Obecnie są tylko jednym z wielu rodów, choć dumni są ze swej długiej historii i wciąż mają ambicję, by do pisania historii przykładać rękę. Jako że ich sława i zasoby przez lata znacznie zmalały, finansują ponoć wyprawy, które mają na celu odzyskanie dawno utraconych skarbów z przeszłości, z zatopionych miast i innych zapomnianych miejsc.",
			Mottos = [
				"Żyje po dwakroć ten, kto żyje dobrze",
				"Bogactwo temu, kto wie, jak go używać",
				"Zamknięte rzeczy są bezpieczne",
				"Niegdyś i na zawsze",
				"Kalibruj i mierz",
				"Bezpieczni na falach",
				"Każdemu jego dola",
				"Żaglem i wiosłami",
				"Pośród pierwszych"
			]
		},
		{
			Traits = [
				this.Const.FactionTrait.NobleHouse,
				this.Const.FactionTrait.Marauder,
				this.Const.FactionTrait.Schemer
			],
			Description = "Większość członków rodu %noblehousename% żyje skryta za grubymi drzwiami i zaryglowanymi okiennicami, a niektórych z nich nie widziano już od lat. Plotka głosi, że ich szlachecka krew splamiona jest szaleństwem i obłędem, lecz nikt nie odważa się wypowiadać tego na głos w obawie przed ich zemstą. Inne rody szlacheckie zazwyczaj unikają kontaktu z rodem %noblehousename%, gdyż nigdy nie wiadomo, czy swego gościa przywitają z otwartymi ramionami, czy bełtem wypuszczonym z kuszy.",
			Mottos = [
				"Nic w życiu nie jest wieczne",
				"Bacz na koniec",
				"Nie gardzimy i nie lękamy się",
				"Nie oceniaj",
				"Wszystko się zmienia",
				"Każdy za siebie",
				"Wszystko jest niestabilne",
				"Strzeż się wilka"
			]
		}
	]
];
gt.Const.CityStateArchetypes <- [
	{
		Traits = [
			this.Const.FactionTrait.OrientalCityState
		],
		Description = "Bogate i niezależne państwo-miasto, skupiające się głównie na handlu i zdobywaniu dalszego bogactwa.",
		Mottos = [
			"Dobrze żyje ten, kto żyje pokojowo",
			"Bogactwo jest moją strzałą",
			"Bogactwo jest naszym mieczem",
			"Złote wieże w oddali",
			"Dary się zwracają",
			"Dajesz i zabierasz"
		]
	},
	{
		Traits = [
			this.Const.FactionTrait.OrientalCityState
		],
		Description = "Państwo-miasto, które poświęciło się przede wszystkim zdobywaniu wiedzy - nawet wtedy, gdy kosztem tego jest wykonywanie autopsji, studiowanie zakazanych tomów czy zajmowanie się złowrogimi mocami nie z tego świata.",
		Mottos = [
			"Ośmiel się być mądrym",
			"Wiedzą zdobywaj fortunę",
			"Czytaj i ucz się",
			"Zamek mądrości",
			"Wreszcie wiedza"
		]
	},
	{
		Traits = [
			this.Const.FactionTrait.OrientalCityState
		],
		Description = "Państwo-miasto rządzone przez bezwzględną radę, która stara się zdobyć władzę za wszelką cenę. Wiele okolicznych tajemniczych śmierci, jak głoszą plotki, to efekty zabójczych zamachów zleconych przez wezyrów z %citystatename%.",
		Mottos = [
			"Wąż w trawie",
			"Z cieni",
			"Za wszelką cenę",
			"Jastrząb nie chwyta much"
		]
	}
];

