gt.Const.Strings.PerkDescription <- {
	Relentless = "Nie zwalniaj! Przez cały czas twoja Inicjatywa jest zmniejszona tylko o [color=" + this.Const.UI.Color.NegativeValue + "]50%[/color] nagromadzonego Zmęczenia, zamiast całości. Ponadto używanie polecenia \'Czekaj\' nie będzie się już wiązało z karą do Inicjatywy w następnej rundzie.",
	Rotation = "Odblokowuje umiejętność \'Rotacja\', która pozwala dwóm postaciom zamienić się miejscami, ignorując Strefę Kontroli, o ile żadna z tych postaci nie jest ogłuszona, zakorzeniona lub w jakiś inny sposób unieruchomiona.",
	Footwork = "Odblokowuje umiejętność \'Praca Nóg\', która dzięki zwinnej pracy nóg pozwala opuścić Strefę Kontroli bez aktywowania darmowego okazyjnego ataku.",
	Debilitate = "Odblokowuje umiejętność \'Osłabienie\', która przygotowuje twój następny atak do osłabienia celu na jedną turę, zmniejszając jego zdolność do zadawania obrażeń o [color=" + this.Const.UI.Color.NegativeValue + "]-50%[/color].",
	Indomitable = "Odblokowuje umiejętność \'Niezłomny\', która na jedną turę daje [color=" + this.Const.UI.Color.PositiveValue + "]50%[/color] redukcji obrażeń i niewrażliwość na ogłuszenie, odrzucenie w tył lub przyciągnięcie.",
	RallyTheTroops = "Odblokowuje umiejętność \'Pokrzepienie Towarzyszy\', która potrafi natchnąć uciekających sojuszników i podnieść morale wszystkich pobliskich sojuszników do stabilnego poziomu. Im wyższa Stanowczość postaci używającej tej umiejętności, tym większa szansa na powodzenie.",
	Adrenaline = "Odblokowuje umiejętność \'Adrenalina\', która stawia cię na przedzie kolejki tur w następnej rundzie, byś mógł wykonać ruch przed wrogiem. Poczuj adrenalinę biegnącą w twoich żyłach!",
	Fearsome = "Spraw, aby rozpierzchli się i uciekali! Każdy atak zadający co najmniej 1 punkt obrażeń zdrowia wyzwala test morale dla przeciwnika z karą równą [color=" + this.Const.UI.Color.NegativeValue + "]15%[/color] twojej Stanowczości, podczas gdy normalnie taki test wykonywany jest bez żadnej kary i przy minimalnie 15 punktach obrażeń.",
	HeadHunter = "Celuj w głowę! Trafienie celu w głowę gwarantuje ci, że kolejny atak również trafi w głowę. Trafienie lub chybienie celu resetuje efekt.",
	SunderingStrikes = "Skuteczność wobec Pancerza zostaje zwiększona o [color=" + this.Const.UI.Color.PositiveValue + "]+20%[/color] dla każdej użytej broni.",
	FastAdaption = "Dostosuj się do ruchów przeciwnika! Otrzymasz dodatkowe, kumulujące się [color=" + this.Const.UI.Color.PositiveValue + "]+10%[/color] szansy na trafienie z każdym atakiem, który chybi przeciwnika. Premia jest resetowana po skutecznym trafieniu w cel.",
	Weaponmaster = "Wszystkie ataki kosztują cię [color=" + this.Const.UI.Color.NegativeValue + "]-20%[/color] Zmęczenia, a kondycja broni zmniejsza się o połowę wolniej. Tańcz wdzięcznie z bronią i niech każde trafienie się liczy. ",
	CoupDeGrace = "Zdaje dodatkowe [color=" + this.Const.UI.Color.PositiveValue + "]20%[/color] obrażeń celom, które już otrzymały jakieś rany, jak np. złamana ręka.",
	SteelBrow = "Trafienia w głowę już nie powodują obrażeń krytycznych dla tej postaci, co także zmniejsza znacznie szansę na wyniszczające rany głowy.",
	Anticipation = "Będąc zaatakowanym z broni dystansowej zyskujesz [color=" + this.Const.UI.Color.PositiveValue + "]1 + 10% swojej bazowej Obrony dystansowej[/color] jako premię do Obrony dystansowej na każde pole odległości między tobą, a atakującym. Jednak zawsze będzie to przynajmniej [color=" + this.Const.UI.Color.PositiveValue + "]+10[/color] do Obrony dystansowej.",
	HoldOut = "Trzymaj się! Każdy negatywny efekt o ograniczonym czasie działania (np. Krwawienie, Urok) trwa krócej o [color=" + this.Const.UI.Color.NegativeValue + "]1[/color] turę. Efekty, których siła słabnie z czasem (jak Goblińska Trucizna) od samego początku są w swoim najsłabszym stadium.",
	Dodge = "Jestem dla ciebie zbyt szybki! Zyskaj [color=" + this.Const.UI.Color.PositiveValue + "]15%[/color] obecnej inicjatywy postaci jako premię do Obrony w zwarciu i Obrony dystansowej.",
	Nimble = "Specjalizuj się w lekkim pancerzu! Zwinnie unikając i parując ataki, zamień każde trafienie w draśnięcie. Otrzymane obrażenia zdrowia są pomniejszone nawet o [color=" + this.Const.UI.Color.PositiveValue + "]60%[/color], choć ta wartość pomniejszona jest wykładniczo o całkowitą karę do maksymalnego Zmęczenia od hełmów i zbroi powyżej [color=" + this.Const.UI.Color.PositiveValue + "]15[/color] punktów. Im lżejszy pancerz, tym bardziej na tym skorzystasz.\n\nTalent \'Krzepki\' nie ma wpływu na ten talent.\n\nNie dotyczy obrażeń od ataków psychicznych i wynikających z różnych efektów, jak np. trucizna czy krwawiące rany, choć czasem pomaga ich uniknąć.",
	BattleForged = "Specjalizuj się w ciężkiej zbroi! Otrzymane obrażenia pancerza zostają pomniejszone o wartość procentową równą [color=" + this.Const.UI.Color.PositiveValue + "]5%[/color] twojego obecnego całkowitego pancerza - sumy pancerza ciała i głowy. Im cięższa zbroja i hełm, tym więcej skorzystasz.\n\nNie dotyczy obrażeń od ataków psychicznych i wynikających z różnych efektów, jak np. trucizna czy krwawiące rany, choć czasem pomaga ich uniknąć.",
	Duelist = "Stań się jednością ze swoją bronią i celuj w słabe punkty! Gdy masz drugą rękę wolną, lub niesiesz w niej przedmiot do rzucania (np. sieć), dodatkowe [color=" + this.Const.UI.Color.PositiveValue + "]+25%[/color] zadawanych przez ciebie obrażeń będzie ignorować pancerz. Nie działa z bronią dwuręczną.",
	CripplingStrikes = "Okulaw swoich wrogów! Zmniejsza o [color=" + this.Const.UI.Color.NegativeValue + "]33%[/color] próg obrażeń do zadawania ran i kontuzji, zarówno dla ataków w zwarciu, jak i dystansowych.",
	QuickHands = "Tego szukałeś? Raz na każdą turę wymienianie przedmiotów w walce, poza tarczami, nie będzie cię kosztować Punktów Akcji.",
	Bullseye = "W dziesiątkę! Kara do szansy na trafienie dla broni dystansowej, gdy nie masz czystej przeciwnika na czystej linii strzału, zostaje pomniejszona z [color=" + this.Const.UI.Color.NegativeValue + "]75%[/color] do [color=" + this.Const.UI.Color.NegativeValue + "]50%[/color].",
	Ballistics = "Kara do szansy trafienia za odległość od celu jest pomniejszona o [color=" + this.Const.UI.Color.NegativeValue + "]-1[/color] na każde pole.",
	Berserk = "RAAARGH! Raz na turę, po zabiciu wroga, natychmiastowo odzyskujesz [color=" + this.Const.UI.Color.PositiveValue + "]4[/color] Punkty Akcji. Postacie nie mogą odzyskać więcej, niż ich maksymalna pula Punktów Akcji i nie więcej niż 4 za jeden atak.",
	BattleFlow = "Raz na turę zabicie przeciwnika obniża twoje obecne zmęczenie o [color=" + this.Const.UI.Color.NegativeValue + "]-25%[/color] podstawowego maksymalnego zmęczenia (zanim doliczone zostaną kary za pancerz).",
	DevastatingStrikes = "Wszystkie zadawane obrażenia zostają zwiększone o [color=" + this.Const.UI.Color.PositiveValue + "]+20%[/color] dla każdej używanej broni. Cóż teraz może stanąć ci na drodze?",
	KillingFrenzy = "Wpadnij w szał zabijania! Zabicie wroga zwiększa zadawane przez ciebie obrażenia o [color=" + this.Const.UI.Color.PositiveValue + "]25%[/color] na 2 tury. Nie kumuluje się, jednak kolejne zabójstwo odnowi licznik czasu.",
	ShieldBash = "Odepchnięcie tarczą teraz dodatkowo zadaje [color=" + this.Const.UI.Color.DamageValue + "]10 - 25[/color] obrażeń (50% skuteczności przeciw pancerzowi) oraz [color=" + this.Const.UI.Color.DamageValue + "]10[/color] Zmęczenia celowi, a użycie umiejętności kosztuje o 10 Zmęczenia mniej.",
	Brawny = "Kara do Zmęczenia i Inicjatywy od noszenia zbroi i hełmu zostaje obniżona o [color=" + this.Const.UI.Color.NegativeValue + "]30%[/color].",
	Stalwart = "Niewrażliwość przeciwko odrzuceniu w tył lub przyciągnięciu. Dotyczy umiejętności takich jak Odepchnięcie, Zahaczenie i innych, które zmieniają pozycję postaci.",
	Steadfast = "Otrzymywanie zwykłych ciosów już nie generuje zmęczenia. Nie dotyczy ataków, które same w sobie mają zwiększać zmęczenie.",
	Taunt = "Odblokowuje umiejętność \'Wydrwij\', która sprawia, że cel podejmie akcje ofensywne, zamiast obronnych i chętniej zaatakuje drwiącą z niego postać, niż jakąś inną, potencjalnie bardziej narażoną.",
	Colossus = "No dawaj! Zdrowie zostaje zwiększone o [color=" + this.Const.UI.Color.PositiveValue + "]25%[/color], co również obniża szansę na otrzymanie wyniszczających ran i kontuzji podczas zostania trafionym.",
	ShieldExpert = "Naucz się lepiej zbijać ciosy, zamiast blokować je na wprost.\n\nPremia do obrony od tarczy zostaje zwiększona o [color=" + this.Const.UI.Color.PositiveValue + "]25%[/color]. To dotyczy również dodatkowej premii do obrony od umiejętności \'Ściana Tarcz\'.\n\nOtrzymane obrażenia tarczy zostają zmniejszone o [color=" + this.Const.UI.Color.NegativeValue + "]50%[/color] do minimum 1.\n\nUmiejętność \'Odepchnij\' otrzymuje [color=" + this.Const.UI.Color.PositiveValue + "]+15%[/color] do szansy trafienia.",
	NineLives = "Raz na bitwę, podczas otrzymywania śmiertelnego ciosu, przeżyjesz z kilkoma punktami zdrowia, a wszelkie efekty zadające obrażenia z czasem (Krwawienie, Trucizna itp.) zostaną usunięte. Następne trafienie zapewne cię zabije, ale podwyższone aż do następnej tury atrybuty obrony pomogą ci nieco dłużej przetrwać.",
	BatteringRam = "Niewrażliwość na ogłuszenie.",
	BagsAndBelts = "Odblokuj dwa dodatkowe miejsca w swojej podręcznej sakwie, aby pomieścić wszystkie twoje ulubione rzeczy. Przedmioty w sakwie, za wyjątkiem broni dwuręcznej, nie dają już kary do maksymalnego Zmęczenia.",
	Student = "Wszystkiego można się nauczyć, gdy się człowiek przyłoży. Zdobywasz o [color=" + this.Const.UI.Color.PositiveValue + "]20%[/color] więcej doświadczenia z bitew. Na jedenastym poziomie postaci zyskasz dodatkowy punkt talentów, a ten talent przestanie działać.\n\nRozgrywając scenariusz \'Łowcy Głów\', twoi zadłużeni otrzymają zwrotny punkt talentów na siódmym poziomie postaci.",
	Gifted = "Żywot najemnika łatwo przychodzi, gdy jesteś naturalnie uzdolnionym. Natychmiastowo zyskujesz awans na wyższy poziom, aby móc zwiększyć atrybuty postaci o maksymalne wartości, jednak nie otrzymujesz dodatkowego talentu.",
	Zweihander = "Koszty zmęczenia dla wszystkich broni dwuręcznych zostają obniżone o [color=" + this.Const.UI.Color.NegativeValue + "]-20%[/color].",
	Pathfinder = "Naucz się poruszać po trudnym terenie. Koszty Punktów Akcji ruchu na każdym terenie zostają obniżone o [color=" + this.Const.UI.Color.NegativeValue + "]-1[/color] do minimum 2 Punktów Akcji na jedno pole, a koszt Zmęczenia jest zredukowany o połowę. Zmienianie wysokości również nie kosztuje już dodatkowych Punktów Akcji.",
	FortifiedMind = "Żelazną wolę niełatwo jest zachwiać. Stanowczość zostaje zwiększona o [color=" + this.Const.UI.Color.PositiveValue + "]25%[/color].",
	Captain = "Użyj sierżanta na polu bitwy, jako przedłużenie swojego dowództwa i aby utrzymać ludzi w szyku. Sojusznicy w zasięgu 5 pól otrzymają [color=" + this.Const.UI.Color.PositiveValue + "]15%[/color] Stanowczości tej postaci jako premię do własnej Stanowczości, maksymalnie do poziomu Stanowczości tej postaci.\n\nNie kumuluje się - liczyć się będzie sierżant z największą Stanowczością.",
	InspiringPresence = "Wielki przywódca inspiruje swych ludzi, aby dali z siebie wszystko i pokonali swe słabości. Sojusznicy rozpoczynają bitwę z wysokimi morale, chyba że cechy charakteru im to uniemożliwiają.",
	Underdog = "Idzie się przyzwyczaić. Ta postać już nie otrzymuje kary do obrony wynikającej z bycia otoczonym przez przeciwników. Jeżeli przeciwnik ma talent \'Skrytobójca\', efekt tego talentu jest negowany i obowiązuje normalna kara za bycie otoczonym.",
	Recover = "Odblokowuje umiejętność \'Odzyskaj Siły\', która pozwala odpocząć przez jedną turę, aby obniżyć nagromadzone Zmęczenie o [color=" + this.Const.UI.Color.NegativeValue + "]50%[/color].",
	Backstabber = "Szlachetnością nie wygrywa się bitew, a dźganiem w czułe miejsca - tak. Premia do szansy na trafienie w walce w zwarciu zostaje zwiększona do [color=" + this.Const.UI.Color.PositiveValue + "]+10%[/color] na każdego sojusznika, który stoi obok wroga.",
	LoneWolf = "Najlepiej pracuje mi się samodzielnie. Gdy w odległości 3 pól nie ma żadnego sojusznika, zyskujesz [color=" + this.Const.UI.Color.PositiveValue + "]15%[/color] premii do Ataku w zwarciu, Ataku dystansowego, Obrony w zwarciu, Obrony dystansowej i Stanowczości.",
	ReachAdvantage = "Naucz się wykorzystywać przewagę zasięgu dużych broni, aby powstrzymać wroga przed zbliżeniem się na tyle, by skutecznie zadał cios.\n\nKażde twoje trafienie bronią dwuręczną daje ci jeden, kumulujący się efekt \'Przewagi Zasięgu\', który zwiększa twoją Obronę w zwarciu o [color=" + this.Const.UI.Color.PositiveValue + "]+5[/color]. Efekt może zostać nałożony maksymalnie 5 razy na turę i trwa do następnej tury tej postaci. Pojedynczy atak trafiający wiele celów może nałożyć efekt kilkukrotnie za jednym razem.\n\nJeżeli odłożysz broń, tracisz wszystkie efekty.",
	Overwhelm = "Naucz się wykorzystywać swoją wysoką Inicjatywę i nie utrudnij wrogowi skuteczne atakowanie przytłaczając go własnymi atakami!\n\nWraz z każdym twoim atakiem, trafionym lub chybionym, wykonanym przeciwko wrogowi, który wykonuje ruch po tobie w danej rundzie, nakładasz na niego efekt \'Przytłoczony\', który obniża jego Atak w zwarciu i Atak dystansowy o [color=" + this.Const.UI.Color.NegativeValue + "]10%[/color] na jedną turę.\n\nEfekt kumuluje się z każdym atakiem i może być nałożony na wiele celów jednocześnie za jednym razem.",
	SpecBow = "Opanuj sztukę łucznictwa i szycia we wrogów strzałami z daleka. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\nZasięg wzroku i maksymalny zasięg strzału łuków zostają zwiększone o [color=" + this.Const.UI.Color.PositiveValue + "]+1[/color].",
	SpecCrossbow = "Opanuj kusze oraz broń palną i naucz się, w jakie miejsca celować najlepiej. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\nDodatkowe [color=" + this.Const.UI.Color.PositiveValue + "]20%[/color] obrażeń zadanych kuszami ignoruje pancerz.\n\nKoszt przeładowania rusznic wynosi teraz [color=" + this.Const.UI.Color.NegativeValue + "]6[/color] Punktów Akcji, dzięki czemu można nimi strzelać co turę, a nie co dwie tury.",
	SpecThrowing = "Opanuj broń miotaną, aby ranić i zabijać wrogów zanim się zbliżą. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\nObrażenia zostają zwiększone o [color=" + this.Const.UI.Color.PositiveValue + "]40%[/color] podczas atakowania celu oddalonego o 2 pola.\n\nObrażenia zostają zwiększone o [color=" + this.Const.UI.Color.PositiveValue + "]20%[/color] podczas atakowania celu oddalonego o 3 pola.",
	SpecAxe = "Opanuj walkę toporami i niszczenie tarcz. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Rozłupanie Tarczy\' zadaje teraz o [color=" + this.Const.UI.Color.PositiveValue + "]50%[/color] więcej obrażeń, jeśli używa się topora.\n\n\'Okrężny Zamach\' ma [color=" + this.Const.UI.Color.PositiveValue + "]+5%[/color] do szansy na trafienie.\n\nDługi topór nie ma już kary do atakowania bezpośrednio przyległych celów.",
	SpecCleaver = "Opanuj tasaki, aby zadawać makabryczne rany. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\nObrażenia od krwawienia zadawane przez tasaki i bicze zostają podwojone odpowiednio do [color=" + this.Const.UI.Color.PositiveValue + "]10[/color] oraz [color=" + this.Const.UI.Color.PositiveValue + "]20[/color] na turę.\n\nRozbrojenie ma tylko połowę kary do szansy trafienia.",
	SpecDagger = "Opanuj szybkie i zabójcze sztylety. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Dźgnij\', \'Przekłuj\' i \'Zabójczy Cios\' mają zmniejszony koszt Punktów Akcji, aby umożliwić wykonanie jednego dodatkowego ataku na turę.",
	SpecSword = "Opanuj sztukę walki na miecze, używając błędów przeciwnika na swoją korzyść. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Riposta\' nie ma już kary do szansy na trafienie\n\n\'Rozetnij\' ma o [color=" + this.Const.UI.Color.NegativeValue + "]50%[/color] niższy próg na zadawanie ran i kontuzji.\n\n\'Rozłup\' i \'Wymach\' zyskują [color=" + this.Const.UI.Color.PositiveValue + "]+5%[/color] do szansy na trafienie.",
	SpecSpear = "Opanuj walkę włóczniami i trzymanie wroga w ryzach. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Ściana Włóczni\' nie zostaje już wyłączona, gdy wróg ją przełamie. Zamast tego nadal daje darmowe ataki na każdego kolejnego wroga, który spróbuje wejść w Strefę Kontroli.\n\nSpisa i Widły Bojowe nie mają już kary do atakowania bezpośrednio przyległych celów.",
	SpecPolearm = "Opanuj broń drzewcową i trzymanie wroga w ryzach. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\nKoszt Punktów Akcji używania umiejętności broni drzewcowych zostaje pomniejszony do [color=" + this.Const.UI.Color.NegativeValue + "]5[/color]. Broń drzewcowa nie ma już kar do atakowania wrogów bezpośrednio przyległych.",
	SpecHammer = "Opanuj młoty i walkę przeciwko ciężko opancerzonym przeciwnikom. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Zniszcz Pancerz\' i \'Zdemoluj Pancerz\' zadają [color=" + this.Const.UI.Color.PositiveValue + "]33%[/color] więcej obrażeń pancerzowi.\n\n\'Roztrzaskaj\' otrzymuje [color=" + this.Const.UI.Color.PositiveValue + "]+5%[/color] do szansy na trafienie.\n\nMłot na drzewcu nie ma już kary do atakowania bezpośrednio przyległych celów.",
	SpecMace = "Opanuj maczugi, aby wytłuc na wrogach posłuszeństwo, czy są opancerzeni, czy nie. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Ogłusz\', \'Przewróć\' i \'Powal\' mają [color=" + this.Const.UI.Color.PositiveValue + "]100%[/color] szansy na ogłuszenie celu, o ile nie jest niewrażliwy.\n\nBuława na drzewcu nie ma już kary do atakowania bezpośrednio przyległych celów.",
	SpecFlail = "Opanuj cepy i omijanie tarczy przeciwnika. Umiejętności generują o [color=" + this.Const.UI.Color.NegativeValue + "]25%[/color] mniej Zmęczenia.\n\n\'Smagaj\' i \'Gradobicie\' ignorują premię do obrony od tarcz.\n\n\'Wymłóć\' otrzymuje [color=" + this.Const.UI.Color.PositiveValue + "]+5%[/color] do szansy na trafienie."
};
gt.Const.Strings.Tooltip <- {
	World = {
		Hint_FocusParty = "Kliknij, by skupić się na oddziale",
		Hint_FocusLocation = "Kliknij, by skupić się na lokacji"
	},
	Tactical = {
		Hint_FocusCharacter = "Kliknij, by skupić się na postaci",
		Hint_CannotChangeItemInCombat = "Nie można zmienić w trakcie bitwy",
