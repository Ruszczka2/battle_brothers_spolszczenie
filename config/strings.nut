gt.Const.Strings.Tactical.TerrainDescription <- [
	"Brak",
	"Droga gruntowa, powstała w wyniku ciągłego używania tej ścieżki przez ludzi i zwierzęta.",
	"Prymitywna droga, składająca się z ubitej gliny.",
	"Brukowana droga, używana przez powozy i inne duże pojazdy.",
	"Krótka trawa na płaskim i twardym gruncie.",
	"Goła i płaska gleba z niemalże całkowitym brakiem roślinności.",
	"Ściółka leśna, pokryta grubą i miękką warstwą mchu.",
	"Ciemna i błotnista gleba.",
	"Głównie stała i pewny grunt, pokryty wysoką i miękką trawą.",
	"Płytka, mętna woda, pokrywająca miękka i grząską ziemię.",
	"Płaska i twarda ziemia, pokryta wysuszonymi trawami.",
	"Twarde skrawki ziemi, kompletnie wyschniętej od słońca i upału.",
	"Płaska i jałowa ziemia, pokryta szorstkimi trawami i chwastami.",
	"Zamarznięta ziemia, przykryta grubą warstwą śniegu.",
	"Zamarznięta ziemia, przykryta płytką warstwą śniegu.",
	"Gładkie skaliste podłoże, zapewniające stabilne oparcie dla stóp.",
	"Twarde skaliste podłoże.",
	"Parząco gorący piasek pustyni.",
	"Czysta i płytka woda"
];
gt.Const.Strings.UI <- {
	Introduction = "Stary tekst, nie ma sensu tłumaczyć. ;)",
	FleeDialogueConsequences = "Czasami lepiej jest wykonać taktyczny odwrót, by ujść z życiem. Twoi ludzie postarają się wówczas dotrzeć samodzielnie do krańców mapy, by móc bezpiecznie się wycofać. Jednakże wróg może ich dogonić, a każda osoba zaangażowana w walkę może nie być w stanie ujść bez szwanku, a nawet z własnym życiem.",
	RetreatDialogueConsequences = "Wrogowie zostali rozbici. Tych kilku, którzy uszli z życiem, rozpierzchło się w różnych kierunkach. Czy zamierzasz ich ścigać, by zdobyć ich głowy i mienie, czy też uznasz bitwę za już wygraną?"
};
